{
  "name": "mpp",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite dev --config=vite.config.ts",
    "build": "vite build --mode client && vite build --mode=production",
    "format": "oxfmt --config='oxfmt.config.ts' --write",
    "lint": "oxlint --config='oxlint.config.ts' --type-aware --type-check --fix-dangerously",
    "check": "bun format && bun lint",
    "check:types": "tsgo --project tsconfig.json --noEmit",
    "types": "wrangler types",
    "deploy": "wrangler deploy",
    "postinstall": "simple-git-hooks"
  },
  "dependencies": {
    "@cloudflare/sandbox": "^0.7.18",
    "@opencode-ai/sdk": "^1.2.27",
    "@xterm/addon-fit": "^0.11.0",
    "@xterm/xterm": "^6.0.0",
    "ghostty-web": "^0.4.0",
    "hono": "^4.12.8"
  },
  "devDependencies": {
    "@cloudflare/vite-plugin": "^1.29.1",
    "@cloudflare/workers-types": "latest",
    "@j178/prek": "^0.3.6",
    "@types/bun": "^1.3.11",
    "@types/node": "^25.5.0",
    "@typescript/native-preview": "^7.0.0-dev.20260320.1",
    "oxfmt": "^0.41.0",
    "oxlint": "^1.56.0",
    "oxlint-tsgolint": "^0.17.1",
    "simple-git-hooks": "^2.13.1",
    "typed-query-selector": "^2.12.1",
    "typescript": "^5.9.3",
    "vite": "^8.0.1",
    "wrangler": "^4.76.0"
  },
  "simple-git-hooks": {
    "pre-commit": "bun prek run --all-files --config='.github/.pre-commit.yml' && bun check"
  },
  "patchedDependencies": {
    "@cloudflare/vite-plugin@1.29.1": "patches/@cloudflare%2Fvite-plugin@1.29.1.patch"
  }
}
